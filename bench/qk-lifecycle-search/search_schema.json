{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "decode_lifecycle_search_run_v1",
  "description": "Machine-readable artifact emitted by extra/qk_lifecycle_search_loop.py per search run.",
  "type": "object",
  "required": [
    "schema", "run_id", "date", "git_commit", "dirty_tree", "evaluator", "suite", "candidates_total",
    "pruned", "executed", "policy_guard_result", "ledger_updates_proposed", "final_decision",
    "next_recommended_project", "default_behavior_changed"
  ],
  "properties": {
    "schema": {"const": "decode_lifecycle_search_run_v1"},
    "run_id": {"type": "string"},
    "date": {"type": "string"},
    "git_commit": {"type": "string"},
    "dirty_tree": {"type": "boolean"},
    "evaluator": {"type": "object", "required": ["path"], "properties": {"path": {"type": "string"}, "candidate_registry": {"type": "string"}}},
    "suite": {"type": ["string", "null"]},
    "candidates_total": {"type": "integer"},
    "pruned": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "decision", "reason"],
        "properties": {
          "id": {"type": "string"},
          "decision": {"type": "string", "enum": ["PRUNE_CLOSED_LANE", "PRUNE_POLICY_VIOLATION", "PRUNE_DUPLICATE_REFUTATION", "PRUNE_MISSING_EVALUATOR_BINDING", "PRUNE_NEEDS_TEMPLATE"]},
          "reason": {"type": "string"},
          "closed_lane": {"type": ["string", "null"]},
          "benchmarked": {"const": false}
        }
      }
    },
    "executed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "decode_eval_candidate_id", "decode_eval_artifact", "decode_eval_verdict", "lifecycle_decision", "artifact_valid"],
        "properties": {
          "id": {"type": "string"},
          "decode_eval_candidate_id": {"type": "string"},
          "command": {"type": "string"},
          "decode_eval_artifact": {"type": ["string", "null"]},
          "decode_eval_verdict": {"type": ["string", "null"]},
          "lifecycle_decision": {"type": "string"},
          "artifact_valid": {"type": ["boolean", "null"]},
          "expected_verdict": {"type": ["string", "null"]},
          "verdict_matches_expected": {"type": ["boolean", "null"]},
          "promotion_decision": {"type": "string"},
          "wd_repro_band_pct": {"type": ["object", "null"]}
        }
      }
    },
    "policy_guard_result": {"type": "string"},
    "ledger_updates_proposed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ledger", "action", "id", "status"],
        "properties": {
          "ledger": {"type": "string"},
          "action": {"type": "string", "enum": ["append_candidate", "append_refutation", "bank_opt_in", "none"]},
          "id": {"type": "string"},
          "status": {"type": "string", "enum": ["proposed", "already_present_skip", "applied"]},
          "reason": {"type": "string"}
        }
      }
    },
    "default_behavior_changed": {"const": false},
    "stop_reason": {"type": ["string", "null"]},
    "final_decision": {
      "type": "string",
      "enum": ["LIFECYCLE_SEARCH_V0_READY", "NEEDS_EVALUATOR_API_CLEANUP", "NEEDS_CANDIDATE_TEMPLATE_LAYER", "NEEDS_POLICY_LANGUAGE_CLEANUP", "NEEDS_LEDGER_NORMALIZATION"]
    },
    "next_recommended_project": {"type": "string"}
  }
}
