{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "decode_candidate_templates_v1",
  "description": "Schema for bench/qk-lifecycle-search/templates.json — the candidate-template registry consumed by extra/qk_candidate_template_gen.py. Templates EXPAND into search_candidates-schema specs; they do not run benchmarks.",
  "type": "object",
  "required": ["schema", "templates", "suites"],
  "properties": {
    "schema": {"const": "decode_candidate_templates_v1"},
    "date": {"type": "string"},
    "comment": {"type": "string"},
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "family", "description", "legal_params", "default_params", "expansion_rule",
                     "closed_lane_guards", "binding_strategy", "expected_lifecycle_decision", "stop_condition", "notes"],
        "properties": {
          "id": {"type": "string"},
          "family": {"type": "string"},
          "description": {"type": "string"},
          "legal_params": {"type": "object"},
          "default_params": {"type": "object"},
          "expansion_rule": {"type": "string"},
          "closed_lane_guards": {"type": "array", "items": {"type": "string"}},
          "binding_strategy": {"type": "string"},
          "expected_lifecycle_decision": {"type": "object"},
          "stop_condition": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    },
    "suites": {"type": "object"}
  }
}
