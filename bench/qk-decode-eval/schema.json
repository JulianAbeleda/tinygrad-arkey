{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "decode_eval_run_v1",
  "description": "Machine-readable verdict artifact emitted by extra/qk_decode_eval.py per candidate run.",
  "type": "object",
  "required": [
    "schema", "candidate_id", "candidate_family", "candidate_description", "date", "git_commit",
    "dirty_tree", "hardware", "perf_state_before", "perf_state_after", "clock_pin_mode", "env",
    "commands", "contexts", "repeats", "warmups", "correctness", "local_ab", "wd", "verdict",
    "verdict_expected", "verdict_matches_expected", "thresholds", "stop_reason", "linked_ledger_entry",
    "source_files", "notes", "default_behavior_changed"
  ],
  "properties": {
    "schema": {"const": "decode_eval_run_v1"},
    "candidate_id": {"type": "string"},
    "candidate_family": {"type": "string"},
    "candidate_description": {"type": "string"},
    "date": {"type": "string"},
    "git_commit": {"type": "string"},
    "dirty_tree": {"type": "boolean"},
    "hardware": {"type": "string"},
    "perf_state_before": {"type": "string"},
    "perf_state_after": {"type": "string"},
    "clock_pin_mode": {"type": "string", "enum": ["auto", "manual_peak_diagnostic_only", "mixed"]},
    "env": {"type": "object"},
    "commands": {"type": "array", "items": {"type": "string"}},
    "contexts": {"type": "array", "items": {"type": "integer"}},
    "repeats": {"type": "integer"},
    "warmups": {"type": ["integer", "null"]},
    "correctness": {
      "type": "object",
      "required": ["checked", "passed"],
      "properties": {
        "checked": {"type": "boolean"},
        "passed": {"type": ["boolean", "null"]},
        "metric": {"type": ["string", "null"]},
        "value": {"type": ["number", "null"]},
        "threshold": {"type": ["number", "null"]},
        "note": {"type": ["string", "null"]}
      }
    },
    "local_ab": {
      "type": "object",
      "required": ["checked"],
      "properties": {
        "checked": {"type": "boolean"},
        "passed": {"type": ["boolean", "null"]},
        "speedup_ctx1024": {"type": ["number", "null"]},
        "threshold_min": {"type": ["number", "null"]},
        "authority": {"type": ["string", "null"]},
        "note": {"type": ["string", "null"]}
      }
    },
    "wd": {
      "type": "object",
      "required": ["checked", "authority"],
      "properties": {
        "checked": {"type": "boolean"},
        "authority": {"type": "string"},
        "per_ctx": {"type": "object"},
        "baseline_per_ctx": {"type": ["object", "null"]},
        "delta_pct": {"type": ["object", "null"]},
        "repro_band_pct": {"type": ["object", "null"]},
        "repro_band_ok": {"type": ["boolean", "null"]},
        "promotion_gate_passed": {"type": ["boolean", "null"]},
        "note": {"type": ["string", "null"]}
      }
    },
    "verdict": {
      "type": "string",
      "comment": "Single source of truth: extra/qk_modes.py Verdict; kept in sync by test/unit/test_verdict_ssot.py.",
      "enum": [
        "PASS_PROMOTE", "PASS_OPT_IN", "PASS_ORACLE_LOCAL_AB", "LOCAL_PASS_WD_FAIL", "FAIL_CORRECTNESS",
        "FAIL_LOCAL_AB", "FAIL_ORACLE_LOCAL_AB", "NEEDS_GPU_STATE_TOOLING", "SELFTEST_PASS", "REST"
      ]
    },
    "verdict_expected": {"type": ["string", "null"]},
    "verdict_matches_expected": {"type": ["boolean", "null"]},
    "thresholds": {"type": "object"},
    "stop_reason": {"type": ["string", "null"]},
    "linked_ledger_entry": {"type": ["string", "null"]},
    "source_files": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "array", "items": {"type": "string"}},
    "default_behavior_changed": {"const": false}
  }
}
