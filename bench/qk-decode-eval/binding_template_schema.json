{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "decode_evaluator_binding_templates_v1",
  "description": "Schema for bench/qk-decode-eval/binding_templates.json — the evaluator-binding contract that a north-star decode-attention candidate must satisfy to become an executable decode_eval candidate. A binding template declares the runners, params, artifact fields, gates, and stop conditions; it does NOT run a kernel. Consumed by the template generator (to stamp candidate requirements) and the lifecycle-search loop (to classify deferred candidates precisely).",
  "type": "object",
  "required": ["schema", "templates"],
  "properties": {
    "schema": {"const": "decode_evaluator_binding_templates_v1"},
    "date": {"type": "string"},
    "comment": {"type": "string"},
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["binding_id", "candidate_family", "role", "comparator", "local_ab_runner", "wd_runner",
                     "correctness_runner", "supported_contexts", "required_candidate_params",
                     "required_artifact_fields", "gates", "stop_conditions", "concrete_runner_status",
                     "missing_for_executable", "notes"],
        "properties": {
          "binding_id": {"type": "string"},
          "candidate_family": {"type": "string"},
          "role": {"type": "string"},
          "comparator": {"type": "string"},
          "local_ab_runner": {"type": "string"},
          "wd_runner": {"type": "string"},
          "correctness_runner": {"type": "string"},
          "supported_contexts": {"type": "array", "items": {"type": "integer"}},
          "required_candidate_params": {"type": "object"},
          "required_artifact_fields": {"type": "array", "items": {"type": "string"}},
          "gates": {
            "type": "object",
            "required": ["structural", "correctness", "local_ab", "wd", "promotion_policy"],
            "properties": {
              "structural": {"type": "string"},
              "correctness": {"type": "string"},
              "local_ab": {"type": "string"},
              "wd": {"type": "string"},
              "promotion_policy": {"type": "string"}
            }
          },
          "stop_conditions": {"type": "array", "items": {"type": "string"}},
          "concrete_runner_status": {"type": "string", "enum": ["deferred_no_kernel", "selftest_stub", "implemented"]},
          "decode_eval_binding": {"type": ["string", "null"]},
          "missing_for_executable": {"type": "array", "items": {"type": "string"}},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
